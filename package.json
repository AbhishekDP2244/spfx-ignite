{
  "name": "gulp-runner",
  "displayName": "Gulp Runner",
  "description": "Run Gulp build pipelines from a chatbot-style UI panel",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gulpRunner.openPanel",
        "title": "Gulp Runner: Open Panel",
        "icon": "$(flame)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gulpRunner",
          "title": "Gulp Runner",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "gulpRunner": [
        {
          "type": "webview",
          "id": "gulpRunner.mainView",
          "name": "Gulp Runner"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "20.x",
    "typescript": "^5.3.2"
  }
}
